# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM="E-Commerce Office <your-email@example.com>"
EMAIL_SECURE=false

# Authentication
JWT_SECRET=replace-with-secure-secret
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/social/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/auth/social/facebook/callback

# Runtime
NODE_ENV=development
PORT=5000
API_PUBLIC_URL=http://localhost:5000
STORE_NAME=E-Commerce Office
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+8801XXXXXXXXX

# Database
MONGODB_URI=mongodb://localhost:27017/ecommerce_office
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2

# Media Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Caching
PUBLIC_SETTINGS_CACHE_TTL_MS=60000
RESPONSE_CACHE_TTL_MS=30000
RESPONSE_CACHE_MAX_ENTRIES=2000
IMAGE_LOOKUP_CACHE_TTL_MS=300000
IMAGE_LOOKUP_CACHE_MAX_ENTRIES=5000
